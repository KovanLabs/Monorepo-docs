{
  "$schema": "https://turborepo.dev/microfrontends/schema.json",
  "applications": {
    "admin": {
      "development": {
        "local": {
          "port": 3001
        }
      }
    },
    "blog": {
      "development": {
        "local": {
          "port": 5173
        }
      },
      "routing": [
        {
          "paths": ["/blog", "/blog/:path*"]
        }
      ]
    },
    "storefront": {
      "development": {
        "local": {
          "port": 3002
        }
      },
      "routing": [
        {
          "paths": ["/store", "/store/:path*"]
        }
      ]
    }
  }
}