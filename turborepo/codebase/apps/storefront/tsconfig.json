{
  "exclude": ["node_modules"],
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "outDir": "dist",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "next.config.ts", "next-env.d.ts", ".next/types/**/*.ts"],
}
