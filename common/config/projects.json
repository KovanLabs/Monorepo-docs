[
  {
    "name": "app-react-one",
    "rushProject": true,
    "rushPackageName": "app-react-one",
    "repo": "https://github.com/RaamPrashath/app-react-one.git",
    "path": "apps/app-react-one",
    "branch": "main",
    "commit": "latest",
    "type": "static",
    "framework": "react-vite",
    "outputPath": "dist",
    "port": 3001,
    "buildCommand": "rushx build",
    "previewCommand": "rushx preview --host 0.0.0.0 --port 3001"
  },
  {
    "name": "app-react-two",
    "rushProject": true,
    "rushPackageName": "app-react-two",
    "repo": "https://github.com/RaamPrashath/app-react-two.git",
    "path": "apps/app-react-two",
    "branch": "main",
    "commit": "latest",
    "type": "static",
    "framework": "react-vite",
    "outputPath": "dist",
    "port": 3002,
    "buildCommand": "rushx build",
    "previewCommand": "rushx preview --host 0.0.0.0 --port 3002"
  },
  {
    "name": "klhrms-client",
    "rushProject": true,
    "rushPackageName": "klhrms",
    "repo": "https://github.com/RaamPrashath/KLHRMS-Client.git",
    "path": "apps/klhrms-client",
    "branch": "dev",
    "commit": "latest",
    "type": "node",
    "framework": "next",
    "outputPath": ".next",
    "port": 3003,
    "buildCommand": "rushx build",
    "previewCommand": "rushx start -p 3003"
  },
  {
    "name": "supastarter",
    "rushProject": false,
    "repo": "https://github.com/RaamPrashath/supastarter.git",
    "path": "apps/supastarter",
    "branch": "main",
    "commit": "latest",
    "type": "nested-monorepo",
    "framework": "supastarter",
    "packageManager": "pnpm@10.28.2",
    "buildCommand": "pnpm build",
    "previewApps": [
      {
        "name": "marketing",
        "relativePath": "apps/marketing",
        "defaultPort": 3001,
        "port": 3004,
        "devCommand": "pnpm --filter marketing exec next dev --port 3004"
      },
      {
        "name": "saas",
        "relativePath": "apps/saas",
        "defaultPort": 3000,
        "port": 3005,
        "devCommand": "pnpm --filter saas exec next dev --port 3005"
      },
      {
        "name": "docs",
        "relativePath": "apps/docs",
        "defaultPort": 3002,
        "port": 3006,
        "devCommand": "pnpm --filter docs exec next dev --port 3006"
      }
    ]
  }
]